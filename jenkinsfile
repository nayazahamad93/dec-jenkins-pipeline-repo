pipeline{
    agent any
    stages{
        stage('stage1'){
            steps{
                sh 'sleep 10'
                echo 'Building...'
            }
        }
        stage('stage2'){
            steps{
                sh '''
                   #!bin/bash
                   pwd
                   ls -lrt
                   sleep 5
                '''
                echo 'This is stage2'
            }
        }
       
        
    }
}  